# Sample configuration for the Photrix media server
# Copy this file to `.env` and adjust the paths to match your environment.

# Root directory containing media files to index
MEDIA_ROOT=./exampleFolder

# Optional: Directory for the SQLite database file (uses <INDEX_DB_LOCATION>/index.db)
# If omitted, defaults to CACHE_DIR (or ./.cache when CACHE_DIR is also unset).
# IMPORTANT: this MUST be a local disk. SQLite uses WAL mode here, which does
# not work over SMB / network filesystems — the read worker hangs indefinitely
# whenever the write worker is active. Keep CACHE_DIR on the network share if
# you want; just point INDEX_DB_LOCATION at a local path.
# INDEX_DB_LOCATION=./.cache

# How often (ms) to run a blocking WAL checkpoint that writes committed frames
# back into index.db and truncates the WAL file. Default 60000 (60s). Passive
# autocheckpoints get starved by the constant background read load, so without
# this sweep the WAL grows without bound (observed at ~1 GB). Set to 0 to disable.
# PHOTRIX_WAL_CHECKPOINT_INTERVAL_MS=60000

# Current baseline matching active `.env` keys (sanitized values)
CACHE_DIR=./.cache

# Maximum size of the media cache (thumbnails / converted images & videos) before
# least-recently-used entries are evicted. Accepts a plain byte count or a suffix
# (KB/MB/GB/TB), e.g. "10GB". Defaults to 10GB. Eviction trims down to 90% of this
# value once exceeded. Only the media cache is affected — the database and model
# downloads under CACHE_DIR are never touched.
# CACHE_MAX_BYTES=10GB

# How often (ms) the cache eviction sweep runs. Default 300000 (5 minutes).
# CACHE_EVICTION_INTERVAL_MS=300000

# Directory for ephemeral HLS output. HLS is generated on demand for video playback
# and deleted shortly after playback stops, so it never accumulates. It defaults to a
# RAM-backed filesystem (/dev/shm on Linux, otherwise the OS temp dir) and should NOT
# point at persistent disk. Override only if /dev/shm is unavailable or too small.
# HLS_CACHE_DIR=/dev/shm/photrix-hls

# How long (ms) an HLS encode/output is kept after the last segment request before it
# is killed and deleted. Default 90000 (90s).
# PHOTRIX_HLS_IDLE_MS=90000

PHOTRIX_OTEL_ENABLED=false
# PHOTRIX_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Server port (default: 3000)
# PORT=3000

# Directory for caching thumbnails and processed files
# CACHE_DIR=./.cache

# Directory for thumbnail cache specifically
# ThumbnailCacheDirectory=./.cache/thumbs

# Optional: Path to a working Python interpreter used for image conversion/thumbnail generation.
# On Windows, prefer the `py` launcher or a full path to python.exe from a python.org install.
# PHOTRIX_PYTHON=C:\\Users\\you\\AppData\\Local\\Programs\\Python\\Python312\\python.exe
# PHOTRIX_PYTHON=py

# Optional: ONNX Runtime provider used by the local InsightFace worker.
# Keep CPUExecutionProvider unless you have a validated CUDA setup.
# PHOTRIX_INSIGHTFACE_PROVIDER=CPUExecutionProvider

# --- Observability / Tracing ---

# Enable OpenTelemetry trace export. When enabled, request and operation spans are
# exported over OTLP HTTP. Jaeger all-in-one can receive this on port 4318.
# PHOTRIX_OTEL_ENABLED=true

# Optional OTLP traces endpoint override.
# PHOTRIX_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Optional logging threshold for per-span console lines.
# PHOTRIX_TRACE_SPAN_MIN_MS=25

# Number of slow spans included in request completion summaries.
# PHOTRIX_TRACE_TOP_SPANS=8
