# Sample configuration for the Photrix media server
# Copy this file to `.env` and adjust the paths to match your environment.

# Root directory containing media files to index
MEDIA_ROOT=./exampleFolder

# Optional: Directory for the SQLite database file (uses <INDEX_DB_LOCATION>/index.db)
# If omitted, defaults to CACHE_DIR (or ./.cache when CACHE_DIR is also unset)
# INDEX_DB_LOCATION=./.cache

# Current baseline matching active `.env` keys (sanitized values)
CACHE_DIR=./.cache
AUTH_BOOTSTRAP_TOKEN=replace-with-long-random-secret
AUTH_TRUSTED_PROXY_IPS=127.0.0.1,::1
AUTH_ALLOWED_HOSTS=localhost
AUTH_REQUIRE_HTTPS=false
AUTH_SECURE_COOKIES=false

# Auth is disabled by default in non-production (NODE_ENV != "production").
# Uncomment to explicitly override:
# AUTH_REQUIRED=true
PHOTRIX_OTEL_ENABLED=false
# PHOTRIX_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Server port (default: 3000)
# PORT=3000

# Directory for caching thumbnails and processed files
# CACHE_DIR=./.cache

# Directory for thumbnail cache specifically
# ThumbnailCacheDirectory=./.cache/thumbs

# Optional: Path to a working Python interpreter used for image conversion/thumbnail generation.
# On Windows, prefer the `py` launcher or a full path to python.exe from a python.org install.
# PHOTRIX_PYTHON=C:\\Users\\you\\AppData\\Local\\Programs\\Python\\Python312\\python.exe
# PHOTRIX_PYTHON=py

# Face metadata pipeline is enabled by default and runs before video conversion.
# Set to false to disable face tagging work.
# PHOTRIX_ENABLE_FACE_METADATA=false

# Set to any value to prevent the server from auto-starting (useful for testing)
# PHOTRIX_NO_AUTOSTART=1

# --- Observability / Tracing ---

# Enable OpenTelemetry trace export. When enabled, request and operation spans are
# exported over OTLP HTTP. Jaeger all-in-one can receive this on port 4318.
# PHOTRIX_OTEL_ENABLED=true

# Optional OTLP traces endpoint override.
# PHOTRIX_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Optional logging threshold for per-span console lines.
# PHOTRIX_TRACE_SPAN_MIN_MS=25

# Number of slow spans included in request completion summaries.
# PHOTRIX_TRACE_TOP_SPANS=8

# --- Authentication / Passkeys ---

# Local development baseline:
# AUTH_ORIGIN=http://localhost:5173
# AUTH_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# AUTH_ALLOWED_HOSTS=localhost
# AUTH_RP_ID=localhost
# AUTH_TRUSTED_PROXY_IPS=
# AUTH_REQUIRE_HTTPS=false
# AUTH_SECURE_COOKIES=false

# Local domain baseline (with hosts entry to loopback):
# AUTH_ORIGIN=http://local.photrix.scottderichards.com:5173
# AUTH_ALLOWED_ORIGINS=http://local.photrix.scottderichards.com:5173,http://localhost:5173,http://localhost:3000
# AUTH_ALLOWED_HOSTS=local.photrix.scottderichards.com,localhost
# AUTH_RP_ID=local.photrix.scottderichards.com
# AUTH_REQUIRE_HTTPS=false
# AUTH_SECURE_COOKIES=false

# Internet-facing production example (reverse proxy at 192.168.1.97):
# AUTH_ORIGIN=https://photrix.scottdrichards.com
# AUTH_ALLOWED_ORIGINS=https://photrix.scottdrichards.com
# AUTH_ALLOWED_HOSTS=photrix.scottdrichards.com
# AUTH_RP_ID=photrix.scottdrichards.com
# AUTH_TRUSTED_PROXY_IPS=192.168.1.97
# AUTH_REQUIRE_HTTPS=true
# AUTH_SECURE_COOKIES=true

# Enable or disable auth gate (default: true)
# AUTH_REQUIRED=true

# Public origin used by the browser app (must match exactly for WebAuthn)
# AUTH_ORIGIN=http://localhost:5173

# Relying party ID for passkeys (domain only, no protocol)
# AUTH_RP_ID=localhost

# Human-readable relying party name shown in credential prompts
# AUTH_RP_NAME=Photrix

# Comma-separated origins allowed to call the API with credentials
# AUTH_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Comma-separated Host header allowlist for incoming requests
# AUTH_ALLOWED_HOSTS=localhost

# Comma-separated trusted reverse proxy IPs. Forwarded headers are ignored unless
# the TCP peer IP is in this list.
# If you see: "Forwarded headers are only accepted from trusted proxies",
# set this to the IP address Photrix sees for your reverse proxy.
# AUTH_TRUSTED_PROXY_IPS=192.168.1.97

# Require HTTPS (or x-forwarded-proto=https from a trusted proxy)
# AUTH_REQUIRE_HTTPS=true

# Strong one-time bootstrap token required to register the first user
# AUTH_BOOTSTRAP_TOKEN=replace-with-long-random-secret

# Session cookie lifetime in seconds (default: 7 days)
# AUTH_SESSION_TTL_SECONDS=604800

# Challenge lifetime in seconds (default: 120)
# AUTH_CHALLENGE_TTL_SECONDS=120

# Max accepted JSON body size for auth endpoints in bytes (default: 16384)
# AUTH_MAX_JSON_BYTES=16384

# Force secure cookies (recommended true in production)
# AUTH_SECURE_COOKIES=false

# Optional auth database directory (uses <AUTH_DB_LOCATION>/auth.db)
# AUTH_DB_LOCATION=./.cache

# In production mode, startup will fail fast when required auth/proxy settings are unsafe.
# Set NODE_ENV=production only when AUTH_* production settings are configured correctly.
