# Sample configuration for the Photrix media server
# Copy this file to `.env` and adjust the paths to match your environment.

# Root directory containing media files to index
MEDIA_ROOT=./exampleFolder

# Path to the SQLite database file for the index
# INDEX_DB_PATH takes precedence over INDEX_DB_LOCATION
INDEX_DB_PATH=./data-index.db

# Optional directory for the SQLite database file (uses <INDEX_DB_LOCATION>/index.db)
# INDEX_DB_LOCATION=./.cache

# Server port (default: 3000)
# PORT=3000

# Directory for caching thumbnails and processed files
# CACHE_DIR=./.cache

# Directory for thumbnail cache specifically
# ThumbnailCacheDirectory=./.cache/thumbs

# Optional: Path to a working Python interpreter used for image conversion/thumbnail generation.
# On Windows, prefer the `py` launcher or a full path to python.exe from a python.org install.
# PHOTRIX_PYTHON=C:\\Users\\you\\AppData\\Local\\Programs\\Python\\Python312\\python.exe
# PHOTRIX_PYTHON=py

# Set to any value to prevent the server from auto-starting (useful for testing)
# PHOTRIX_NO_AUTOSTART=1
