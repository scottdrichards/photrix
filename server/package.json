{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npx tsx src/main.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects unit",
    "test:all": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects integration --runInBand",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects unit --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"{src,tests}/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"{src,tests}/**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@simplewebauthn/server": "^13.2.2",
    "better-sqlite3": "^12.5.0",
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.5",
    "exifr": "^7.1.3",
    "heic-convert": "^2.1.0",
    "minimatch": "^9.0.4",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/heic-convert": "^2.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.5.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.44.1"
  }
}
